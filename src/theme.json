{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "light-dark(#F5F5F5, #000)",
					"name": "Background Light / Background Dark",
					"slug": "background"
				},
				{
					"color": "#FFFFFF",
					"name": "White",
					"slug": "white"
				},
				{
					"color": "#000000",
					"name": "Black",
					"slug": "black"
				},
				{
					"color": "#E2000F",
					"name": "Primary",
					"slug": "primary"
				},
				{
					"color": "#333333",
					"name": "Secondary",
					"slug": "secondary"
				},
				{
					"color": "#FCB700",
					"name": "Tertiary",
					"slug": "tertiary"
				},
				{
					"color": "light-dark(#FFF, #000)",
					"name": "Light / Dark",
					"slug": "light"
				},
				{
					"color": "light-dark(#000, #FFF)",
					"name": "Dark / Light",
					"slug": "dark"
				},
				{
					"color": "light-dark(#e5e5e5, #333333)",
					"name": "Medium Light / Medium Dark",
					"slug": "medium"
				}
			]
		},
		"layout": {
			"contentSize": "750px",
			"wideSize": "1300px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "XX-Small",
					"size": "4px",
					"slug": "xx-small"
				},
				{
					"name": "X-Small",
					"size": "6px",
					"slug": "x-small"
				},
				{
					"name": "Small",
					"size": "12px",
					"slug": "small"
				},
				{
					"name": "Base",
					"size": "24px",
					"slug": "base"
				},
				{
					"name": "Large",
					"size": "36px",
					"slug": "large"
				},
				{
					"name": "X-Large",
					"size": "48px",
					"slug": "x-large"
				},
				{
					"name": "XX-Large",
					"size": "64px",
					"slug": "xx-large"
				}
			],
			"units": [
				"%",
				"px",
				"em",
				"rem",
				"vh",
				"vw"
			]
		},
		"typography": {
			"writingMode": true,
			"defaultFontSizes": false,
			"fluid": true,
			"fontSizes": [
				{
					"fluid": false,
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "1rem",
						"min": "1rem"
					},
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "1.375rem",
						"min": "1.125rem"
					},
					"name": "Large",
					"size": "1.38rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "1.75rem",
						"min": "1.5rem"
					},
					"name": "Extra Large",
					"size": "1.75rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "3rem",
						"min": "2.15rem"
					},
					"name": "Extra Extra Large",
					"size": "2.15rem",
					"slug": "xx-large"
				}
			],
			"fontFamilies": [
				{
					"name": "Montserrat",
					"slug": "montserrat",
					"fontFamily": "Montserrat, sans-serif",
					"fontFace": [
						{
							"src": [
								"file:./assets/fonts/montserrat/Montserrat-VariableFont_wght.ttf"
							],
							"fontWeight": "100 200 300 400 500 600 700 800 900",
							"fontStyle": "normal",
							"fontFamily": "Montserrat"
						}
					]
				}
			]
		},
		"border": {
			"radius": true,
			"radiusSizes": [
				{
					"name": "Small",
					"slug": "sm",
					"size": "0.25rem"
				},
				{
					"name": "Base",
					"slug": "base",
					"size": "6px"
				},
				{
					"name": "Large",
					"slug": "large",
					"size": "12px"
				},
				{
					"name": "X-Large",
					"slug": "x-large",
					"size": "24px"
				},
				{
					"name": "Round",
					"slug": "round",
					"size": "9999px"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"spacing": {
			"blockGap": "var:preset|spacing|base",
			"padding": {
				"left": "var:preset|spacing|base",
				"right": "var:preset|spacing|base"
			}
		},
		"typography": {
			"fontFamily": "var:preset|font-family|montserrat",
			"fontSize": "var:preset|font-size|medium",
			"fontWeight": "400",
			"fontColor": "var:preset|color|dark"
		},
		"blocks": {
			"core/button": {
				"variations": {
					"primary": {
						"color": {
							"background": "var(--wp--preset--color--primary)",
							"text": "var(--wp--preset--color--white)"
						}
					}
				}
			},
			"core/columns": {
				"spacing": {
					"blockGap": "var:preset|spacing|base"
				}
			},
			"core/buttons": {
				"spacing": {
					"blockGap": "16px"
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/separator": {
				"border": {
					"color": "currentColor",
					"style": "solid",
					"width": "0 0 1px 0"
				},
				"color": {
					"text": "var:preset|color|primary"
				},
				"variations": {
					"wide": {
						"css": " &:not(.alignfull){max-width: var(--wp--style--global--wide-size) !important;}"
					}
				}
			},
			"core/site-tagline": {
				"typography": {
					"fontSize": "var:preset|font-size|medium"
				}
			},
			"core/site-title": {
				"typography": {
					"fontWeight": "700",
					"letterSpacing": "-.5px"
				},
				"elements": {
					"link": {
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var:preset|font-size|medium"
				},
				"elements": {
					"link": {
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/list": {
				"css": "& li{margin-top: 0.5rem;}"
			}
		},
		"elements": {
			"button": {
				"color": {
					"background": "var:preset|color|secondary",
					"text": "var:preset|color|white"
				},
				"border": {
					"radius": {
						"topLeft": "var:preset|border-radius|base",
						"topRight": "var:preset|border-radius|base",
						"bottomLeft": "var:preset|border-radius|base",
						"bottomRight": "var:preset|border-radius|base"
					}
				},
				"spacing": {
					"padding": {
						"bottom": "var:preset|spacing|xx-small",
						"left": "var:preset|spacing|base",
						"right": "var:preset|spacing|base",
						"top": "var:preset|spacing|xx-small"
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|medium",
					"textTransform": "uppercase"
				}
			},
			"caption": {
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"lineHeight": "1.4"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|xx-large"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|x-large"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|large"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|medium"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"letterSpacing": "0.5px"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "700",
					"letterSpacing": "1.4px",
					"textTransform": "uppercase"
				}
			},
			"heading": {
				"typography": {
					"fontWeight": "900",
					"lineHeight": "1.125",
					"letterSpacing": "-0.1px",
					"textAlign": "center",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var:preset|color|dark"
				},
				"spacing": {
					"padding": {
						"left": "var:preset|spacing|base",
						"right": "var:preset|spacing|base",
						"top": "var:preset|spacing|small",
						"bottom": "var:preset|spacing|small"
					}
				}
			},
			"link": {
				"color": {
					"text": "currentColor"
				},
				":hover": {
					"typography": {
						"textDecoration": "none"
					}
				}
			}
		}
	},
	"templateParts": [
		"footer"
	],
	"customTemplates": []
}